# ── Secrets / credentials — never commit (matches anywhere in the tree) ──
# Env files (the bare `.env` above only matches that exact name)
*.env
*.env.*
# but keep templated examples that are meant to be shared
!*.env.example
!*.env.sample
!*.env.template
# Private keys / certs
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
.netrc
.npmrc
# Credential / API-key / auth JSON blobs
auth-profiles.json
*api-key*.json
*apikey*.json
*-claimed-api-key.json
*credentials*.json
secrets.json
*.secret
